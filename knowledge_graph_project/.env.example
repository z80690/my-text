# -*- coding: utf-8 -*-
"""
知识图谱数据库项目环境配置
Knowledge Graph Database Project Environment Configuration

注意：复制此文件为 .env 并填写实际值
"""

# ==================== 数据库配置 ====================

# Supabase 配置 (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Neo4j 图数据库配置 (可选，用于高级图查询)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ==================== 哔哩哔哩配置 ====================

# 哔哩哔哩登录配置
BILIBILI_COOKIES_FILE=data/bilibili_cookies.json
BILIBILI_LOGIN_METHOD=qrcode  # qrcode, password, sms
BILIBILI_SAVE_PATH=data/bilibili/

# 哔哩哔哩API配置
BILIBILI_API_BASE=https://api.bilibili.com
BILIBILI_PASSPORT_API=https://passport.bilibili.com

# ==================== 今日头条配置 ====================

# 今日头条登录配置
TOUTIAO_COOKIES_FILE=data/toutiao_cookies.json
TOUTIAO_LOGIN_METHOD=qrcode  # qrcode, password
TOUTIAO_SAVE_PATH=data/toutiao/

# 今日头条API配置
TOUTIAO_API_BASE=https://www.toutiao.com
TOUTIAO_API_V2=https://www.toutiao.com/api

# ==================== 应用配置 ====================

# 服务器配置
HOST=0.0.0.0
PORT=8080
ENVIRONMENT=development  # development, production
DEBUG=True

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 会话配置
SESSION_SECRET=your-session-secret-key-change-in-production
SESSION_EXPIRE_HOURS=24

# 加密配置
ENCRYPTION_KEY=your-encryption-key-32-chars

# 代理配置 (可选)
HTTP_PROXY=
HTTPS_PROXY=
BILIBILI_PROXY=
TOUTIAO_PROXY=

# 验证码配置 (可选)
CAPTCHA_API_KEY=your-captcha-api-key
CAPTCHA_API_URL=http://your-captcha-service/

# 速率限制
REQUEST_DELAY=1.0  # 请求间隔(秒)
MAX_RETRIES=3
TIMEOUT=30
