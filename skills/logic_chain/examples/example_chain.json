{
  "chain_name": "User Registration Flow",
  "description": "Demonstrates IF/ELSE branching logic with user registration",
  "version": "1.0.0",
  "nodes": [
    {
      "node_id": "start",
      "node_type": "skill",
      "name": "Start Registration",
      "skill_name": "dummy_start",
      "parameters": {},
      "metadata": {
        "next": {"default": "validate_email"}
      }
    },
    {
      "node_id": "validate_email",
      "node_type": "condition",
      "name": "Validate Email Format",
      "condition": "$email matches .*@.*\\..*",
      "output_key": "email_valid",
      "metadata": {
        "next": {"default": "if_email_valid"}
      }
    },
    {
      "node_id": "if_email_valid",
      "node_type": "if_else",
      "name": "IF Email Valid",
      "condition_node_id": "validate_email",
      "metadata": {
        "next": {
          "true": "check_user_exists",
          "false": "reject_email"
        }
      }
    },
    {
      "node_id": "check_user_exists",
      "node_type": "skill",
      "name": "Check if User Exists",
      "skill_name": "check_user_exists",
      "parameters": {
        "email": "$email"
      },
      "output_key": "user_found",
      "metadata": {
        "next": {"default": "if_user_not_exists"}
      }
    },
    {
      "node_id": "if_user_not_exists",
      "node_type": "if_else",
      "name": "IF User Not Found",
      "condition_node_id": "check_user_exists",
      "metadata": {
        "next": {
          "true": "create_user",
          "false": "reject_user_exists"
        }
      }
    },
    {
      "node_id": "create_user",
      "node_type": "skill",
      "name": "Create New User",
      "skill_name": "create_user",
      "parameters": {
        "email": "$email",
        "name": "$name"
      },
      "metadata": {
        "next": {"default": "send_welcome"}
      }
    },
    {
      "node_id": "send_welcome",
      "node_type": "skill",
      "name": "Send Welcome Email",
      "skill_name": "send_welcome_email",
      "parameters": {
        "email": "$email",
        "name": "$name"
      },
      "metadata": {
        "next": {"default": "end_success"}
      }
    },
    {
      "node_id": "reject_email",
      "node_type": "skill",
      "name": "Reject - Invalid Email",
      "skill_name": "reject_registration",
      "parameters": {
        "reason": "Invalid email format"
      },
      "metadata": {
        "next": {"default": "end_error"}
      }
    },
    {
      "node_id": "reject_user_exists",
      "node_type": "skill",
      "name": "Reject - User Exists",
      "skill_name": "reject_registration",
      "parameters": {
        "reason": "User with this email already exists"
      },
      "metadata": {
        "next": {"default": "end_error"}
      }
    },
    {
      "node_id": "end_success",
      "node_type": "skill",
      "name": "Registration Complete",
      "skill_name": "log_success",
      "parameters": {
        "message": "User registration successful"
      },
      "metadata": {}
    },
    {
      "node_id": "end_error",
      "node_type": "skill",
      "name": "Registration Failed",
      "skill_name": "log_error",
      "parameters": {
        "message": "User registration failed"
      },
      "metadata": {}
    }
  ]
}
