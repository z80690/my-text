{
  "workflows": {
    "directory": ".trae/workflows",
    "default_template": "parallel_gateway",
    "enforce_parallel": true,
    "max_concurrent_tasks": 10,
    "task_timeout": 300,
    "log_level": "INFO",
    "monitor_agent_id": "monitor_agent",
    "max_recursion_depth": 3,
    "auto_monitor": true
  },
  "registered_workflows": [
    {
      "name": "test_workflow",
      "description": "测试工作流",
      "template": "parallel_gateway",
      "parameters": []
    },
    {
      "name": "agent_task",
      "description": "智能体任务工作流（默认并行）",
      "template": "parallel_gateway",
      "parameters": [
        {
          "name": "agent_id",
          "type": "string",
          "required": true,
          "description": "智能体ID"
        },
        {
          "name": "task",
          "type": "string",
          "required": true,
          "description": "任务描述"
        },
        {
          "name": "monitor",
          "type": "boolean",
          "default": true,
          "description": "是否启用监控"
        }
      ]
    },
    {
      "name": "parallel_tasks",
      "description": "多任务并行工作流",
      "template": "parallel_gateway",
      "parameters": [
        {
          "name": "branches",
          "type": "array",
          "required": true,
          "description": "并行任务分支"
        },
        {
          "name": "max_depth",
          "type": "integer",
          "default": 3,
          "description": "最大递归深度"
        }
      ]
    }
  ]
}