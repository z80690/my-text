{
  "version": "1.0",
  "description": "工具调用追踪系统配置",
  "tracking": {
    "enabled": true,
    "auto_generate_report": true,
    "report_time": "23:59",
    "log_retention_days": 30,
    "report_retention_days": 90
  },
  "mcp_tools": {
    "auto-memory": {
      "description": "自动记忆MCP - 收到消息自动识别暗知识并记忆",
      "endpoints": ["write_memory"]
    },
    "auto-workflow": {
      "description": "自动工作流MCP",
      "endpoints": ["execute", "schedule"]
    },
    "knowledge-graph": {
      "description": "知识图谱MCP",
      "endpoints": ["query", "update", "traverse"]
    },
    "trae-auto-memory": {
      "description": "TRAE自动记忆MCP",
      "endpoints": ["write", "read", "search"]
    }
  },
  "skill_tools": {
    "auto-memory": {
      "description": "自动记忆技能",
      "actions": ["remember", "recall", "forget"]
    },
    "file-cleaner": {
      "description": "智能文件清理技能",
      "actions": ["scan", "analyze", "clean"]
    },
    "my-code-review": {
      "description": "代码审查技能",
      "actions": ["review", "suggest", "report"]
    },
    "nuwa-skill": {
      "description": "女娲造人技能 - 蒸馏人物视角",
      "actions": ["distill", "research", "generate"]
    }
  },
  "alerts": {
    "error_rate_threshold": 0.1,
    "slow_call_threshold_ms": 5000,
    "notify_on_high_error_rate": true
  }
}
