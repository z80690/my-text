{
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:watch": "eslint . --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:diff": "prettier --diff .",
    "format:watch": "prettier --write . --watch",
    "dev:lint": "echo 'ESLint 监控模式暂不可用（ESLint 9 Flat Config 限制）' && npx eslint . --max-warnings=0",
    "dev:format": "prettier --write . --watch --ignore-path .prettierignore",
    "dev:all": "echo '注意: 文件监控需要使用外部工具（如 chokidar 或 nodemon）'",
    "quality:check": "npm run lint; npm run format:check; npm run lint:python",
    "quality:fix": "npm run format; npm run lint:fix; npm run lint:python:fix",
    "lint:python": "pylint --rcfile=../src/.pylintrc ../src/*.py",
    "lint:python:fix": "pylint ../src/*.py --disable=all --enable=fixme",
    "spec:check": "openspec validate --all --json",
    "spec:check:strict": "openspec validate --all --strict",
    "full:check": "npm run quality:check; npm run spec:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.6.0",
    "globals": "^15.9.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.53.1"
  }
}
